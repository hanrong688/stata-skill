/* ============================================================
   SUMMARY
   ============================================================ */
display as text _n "{hline 60}"
display as text "CROSS-VALIDATION SUMMARY"
display as text "{hline 60}"
display as text "  Passed: " as result ${splink_val_pass}
display as text "  Failed: " as error ${splink_val_fail}
display as text "{hline 60}"

if ${splink_val_fail} > 0 {
    display as error "SOME CROSS-VALIDATION TESTS FAILED"
    exit 1
}
else {
    display as text "ALL CROSS-VALIDATION TESTS PASSED"
}

macro drop splink_val_pass splink_val_fail
