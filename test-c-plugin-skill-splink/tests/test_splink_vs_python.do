restore


/* ============================================================
   CONFIG G: Multi-blocking (>4 rules)
   ============================================================ */
display as text _n "{hline 60}"
display as text "CONFIG G: Multi-blocking (5 rules)"
display as text "{hline 60}"

use `input_data', clear

* 5 blocking rules via blockrules()
splink first_name last_name email, ///
    blockrules("city ; dob ; first_name ; last_name ; email") gen(stata_cid) ///
    compmethod(jw jw jw) ///
    complevels("0.92,0.80|0.92,0.80|0.92,0.80") ///
    prior(0.05) threshold(0.5) ///
    uestimate umaxpairs(100000) useed(42) ///
    verbose replace

