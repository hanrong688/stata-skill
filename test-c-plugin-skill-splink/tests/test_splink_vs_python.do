/* ============================================================
   CONFIG F: TF adjustment with named columns
   ============================================================ */
display as text _n "{hline 60}"
display as text "CONFIG F: TF with named columns"
display as text "{hline 60}"

use `input_data', clear

tempfile pairs_f
splink first_name last_name dob, ///
    block(city) gen(stata_cid) ///
    compmethod(jw jw jw) ///
    complevels("0.92,0.80|0.92,0.80|0.92,0.80") ///
    prior(0.05) threshold(0.5) ///
    tfadjust(first_name last_name) tfmin(0.001) ///
    uestimate umaxpairs(100000) useed(42) ///
    savepairs("`pairs_f'") verbose replace

preserve
