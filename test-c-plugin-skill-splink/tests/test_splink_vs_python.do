display as text "  Stata  purity: " %6.3f `stata_purity_c'

if `stata_purity_c' >= 0.75 {
    _vtest_pass "Config C: Stata purity >= 0.75 (`=string(`stata_purity_c',"%5.3f")')"
}
else {
    _vtest_fail "Config C: Stata purity = `=string(`stata_purity_c',"%5.3f")' (< 0.75)"
}


/* ============================================================
   CONFIG D: TF adjustment on last_name
   ============================================================ */
display as text _n "{hline 60}"
display as text "CONFIG D: TF adjustment on last_name"
display as text "{hline 60}"

use `input_data', clear

splink first_name last_name dob email, ///
    block(city) gen(stata_cid) ///
    compmethod(jw jw jw jw) ///
    complevels("0.92,0.80|0.92,0.80|0.92,0.80|0.92,0.80") ///
    prior(0.05) threshold(0.5) ///
    tfadjust(last_name) tfmin(0.001) ///
    uestimate umaxpairs(100000) useed(42) ///
    verbose replace

preserve
import delimited "`val_dir'/config_d_tf_adj_clusters.csv", clear
rename cluster_id python_cid
keep unique_id python_cid
tempfile py_clusters_d
save `py_clusters_d'
restore

merge 1:1 unique_id using `py_clusters_d', nogenerate

