* Check named TF columns in pairwise output
preserve
import delimited "`pairs_f'", clear
capture confirm variable tf_first_name_l
if _rc == 0 {
    _vtest_pass "Config F: tf_first_name_l column present in pairwise output"
}
else {
    _vtest_fail "Config F: tf_first_name_l column missing from pairwise output"
}
capture confirm variable tf_last_name_l
if _rc == 0 {
    _vtest_pass "Config F: tf_last_name_l column present in pairwise output"
}
else {
    _vtest_fail "Config F: tf_last_name_l column missing from pairwise output"
