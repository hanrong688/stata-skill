------------------------------------------------------------

. 
. list first_name last_name cluster_id, sep(0)

     +----------------------------------+
     | first_~e    last_name   cluste~d |
     |----------------------------------|
  1. |     john        smith          1 |
  2. |     john        smtih          1 |
  3. |   robert     williams          2 |
  4. |   robert      wiliams          2 |
  5. | jennifer     martinez          3 |
  6. | jennifer      martnez          3 |
  7. |    alice   completely          4 |
  8. |      bob    different          5 |
     +----------------------------------+

. 
. * Fuzzy matches should cluster (smtih~smith, wiliams~williams, martnez~martin
> ez)
. if cluster_id[1] == cluster_id[2] {
.     _test_pass "smith/smtih fuzzy matched"
  PASS: smith/smtih fuzzy matched
. }

. else {
.     _test_fail "smith/smtih NOT fuzzy matched"
. }

. 
. if cluster_id[3] == cluster_id[4] {
.     _test_pass "williams/wiliams fuzzy matched"
  PASS: williams/wiliams fuzzy matched
. }

. else {
.     _test_fail "williams/wiliams NOT fuzzy matched"
. }

. 
. if cluster_id[5] == cluster_id[6] {
.     _test_pass "martinez/martnez fuzzy matched"
  PASS: martinez/martnez fuzzy matched
. }

. else {
.     _test_fail "martinez/martnez NOT fuzzy matched"
. }

. 
. * Completely different records should NOT cluster
. if cluster_id[7] != cluster_id[8] {
.     _test_pass "alice/bob not clustered (different names)"
  PASS: alice/bob not clustered (different names)
. }

. else {
.     _test_fail "alice/bob incorrectly clustered"
. }

. 
