. /*
>     test_splink.do — Comprehensive test suite for splink
> 
>     Run from the package root directory:
>         cd /path/to/test-c-plugin-skill-splink
>         do tests/test_splink.do
> 
>     Requires: splink_plugin compiled for current platform
> */
. 
. clear all

. set more off

. 
. * Use globals for test counters (programs can't see caller locals)
. * Note: avoid underscore prefix — Stata reserves those for system globals
. global splink_n_pass 0

. global splink_n_fail 0

. 
. capture program drop _test_pass

. program define _test_pass
  1.     args msg
  2.     display as text "  PASS: `msg'"
  3.     global splink_n_pass = ${splink_n_pass} + 1
  4. end

. 
. capture program drop _test_fail

. program define _test_fail
  1.     args msg
  2.     display as error "  FAIL: `msg'"
  3.     global splink_n_fail = ${splink_n_fail} + 1
  4. end

. 
. 
. /* ============================================================
>    TEST 1: Exact duplicates (basic dedup)
>    Block on city so all "new york" records are compared.
>    ============================================================ */
. display as text _n "{hline 60}"

------------------------------------------------------------

. display as text "TEST 1: Exact duplicates"
TEST 1: Exact duplicates

. display as text "{hline 60}"
------------------------------------------------------------

. 
. clear

. input str20 first_name str20 last_name int dob_year str20 city

               first_name             last_name  dob_year                  city
  1. "john"      "smith"     1985  "new york"
  2. "john"      "smith"     1985  "new york"
  3. "mary"      "johnson"   1990  "chicago"
  4. "mary"      "johnson"   1990  "chicago"
  5. "patricia"  "brown"     1988  "phoenix"
  6. "david"     "garcia"    1992  "seattle"
  7. "david"     "garcia"    1992  "seattle"
  8. end

. 
. splink first_name last_name dob_year city, block(city) gen(cluster_id)

------------------------------------------------------------
  Splink: Probabilistic Record Linkage
------------------------------------------------------------
  Observations:                7
  Threshold:               0.850
------------------------------------------------------------
  Cluster ID stored in: cluster_id
------------------------------------------------------------

. 
. * Exact duplicates should cluster
. if cluster_id[1] == cluster_id[2] {
.     _test_pass "john smith exact duplicates clustered"
  PASS: john smith exact duplicates clustered
. }

. else {
.     _test_fail "john smith exact duplicates NOT clustered"
. }

. 
. if cluster_id[3] == cluster_id[4] {
.     _test_pass "mary johnson exact duplicates clustered"
  PASS: mary johnson exact duplicates clustered
. }

. else {
.     _test_fail "mary johnson exact duplicates NOT clustered"
. }

. 
. if cluster_id[6] == cluster_id[7] {
.     _test_pass "david garcia exact duplicates clustered"
  PASS: david garcia exact duplicates clustered
. }

. else {
.     _test_fail "david garcia exact duplicates NOT clustered"
. }

. 
. * Unique record should have its own cluster
. quietly levelsof cluster_id if first_name == "patricia", local(pat_cids)

. local n_pat : word count `pat_cids'

. if `n_pat' == 1 {
.     _test_pass "patricia brown has own cluster"
  PASS: patricia brown has own cluster
. }

. else {
.     _test_fail "patricia brown does NOT have own cluster"
. }

. 
. * Different cities should not cross-cluster
. if cluster_id[1] != cluster_id[3] {
.     _test_pass "different-city records not clustered"
  PASS: different-city records not clustered
. }

. else {
.     _test_fail "different-city records incorrectly clustered"
. }

. 
. 
