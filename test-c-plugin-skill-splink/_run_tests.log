. /* ============================================================
>    TEST 7: threshold() affects matching
>    ============================================================ */
. display as text _n "{hline 60}"

------------------------------------------------------------

. display as text "TEST 7: threshold() effect"
TEST 7: threshold() effect

. display as text "{hline 60}"
------------------------------------------------------------

. 
. clear

. input str20 first_name str20 last_name str10 city

               first_name             last_name        city
  1. "john"    "smith"      "denver"
  2. "john"    "smith"      "denver"
  3. "john"    "smyth"      "denver"
  4. end

. 
. * High threshold: only exact matches
. splink first_name last_name, block(city) gen(cid_high) thr(0.99)

------------------------------------------------------------
  Splink: Probabilistic Record Linkage
------------------------------------------------------------
  Observations:                3
  Threshold:               0.990
------------------------------------------------------------
  Cluster ID stored in: cid_high
------------------------------------------------------------

. local n_clusters_high = r(n_clusters)

. local n_matches_high = r(n_matches)

. 
. * Low threshold: fuzzy matches too
. splink first_name last_name, block(city) gen(cid_low) thr(0.3)

------------------------------------------------------------
  Splink: Probabilistic Record Linkage
------------------------------------------------------------
  Observations:                3
  Threshold:               0.300
------------------------------------------------------------
  Cluster ID stored in: cid_low
------------------------------------------------------------

. local n_clusters_low = r(n_clusters)

. local n_matches_low = r(n_matches)

. 
. display as text "  High threshold (0.99): `n_matches_high' matches, `n_cluste
> rs_high' clusters"
  High threshold (0.99): 0 matches, 3 clusters

. display as text "  Low threshold (0.30):  `n_matches_low' matches, `n_cluster
> s_low' clusters"
  Low threshold (0.30):  3 matches, 1 clusters

. 
. * Lower threshold should produce >= matches
. if `n_matches_low' >= `n_matches_high' {
.     _test_pass "lower threshold produces >= matches"
  PASS: lower threshold produces >= matches
. }

. else {
.     _test_fail "lower threshold did NOT produce more matches"
. }

. 
