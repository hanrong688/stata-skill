. clear

. input str20 first_name str20 last_name int dob_year str20 city

               first_name             last_name  dob_year                  city
  1. "john"      "smith"     1985  "houston"
  2. "john"      "smtih"     1985  "houston"
  3. "robert"    "williams"  1975  "houston"
  4. "robert"    "wiliams"   1975  "houston"
  5. "jennifer"  "martinez"  1990  "houston"
  6. "jennifer"  "martnez"   1990  "houston"
  7. "alice"     "completely" 1980 "houston"
  8. "bob"       "different" 1970  "houston"
  9. end

. 
. * Block on city so all Houston records are compared
. splink first_name last_name dob_year, block(city) gen(cluster_id) verbose
splink: n=8 n_comp=3 has_link=0 threshold=0.850 max_iter=25
