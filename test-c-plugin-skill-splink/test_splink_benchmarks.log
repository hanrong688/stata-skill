. /*
>     test_splink_benchmarks.do — Benchmark against splink's real datasets
> 
>     Tests the Stata plugin against splink's built-in datasets which have
>     known ground truth entity IDs, allowing precision/recall measurement.
> 
>     Prerequisite: run export_splink_datasets.py first to create CSVs.
> 
>     Metrics:
>       Purity    = fraction of predicted clusters containing only one true ent
> ity
>                   (precision proxy: are the clusters clean?)
>       Completeness = fraction of true entities contained in only one cluster
>                   (recall proxy: did we find all the matches?)
> */
. 
. clear all

. set more off

. 
. /* ============================================================
>    UTILITY: Compute pairwise precision/recall
>    ============================================================ */
. capture program drop _linkage_metrics

. program define _linkage_metrics, rclass
  1.     * Computes purity and completeness given cluster_id and true_entity_id
.     * Assumes these variables exist in the current dataset
.     args cluster_var entity_var
  2. 
.     tempvar tag1 n_entities tag2 n_clusters
  3. 
.     * --- Purity: fraction of predicted clusters with only 1 true entity ---
.     * Tag first occurrence of each (cluster, entity) combination
.     bysort `cluster_var' `entity_var': gen byte `tag1' = (_n == 1)
  4.     bysort `cluster_var': egen int `n_entities' = total(`tag1')
  5. 
.     * A cluster is "pure" if it contains records from only 1 true entity
.     tempvar is_pure
  6.     bysort `cluster_var': gen byte `is_pure' = (`n_entities' == 1)
  7.     * Count distinct clusters
.     tempvar cluster_tag
  8.     bysort `cluster_var': gen byte `cluster_tag' = (_n == 1)
  9.     quietly count if `cluster_tag' == 1
 10.     local total_clusters = r(N)
 11.     quietly count if `cluster_tag' == 1 & `is_pure' == 1
 12.     local pure_clusters = r(N)
 13.     local purity = `pure_clusters' / `total_clusters'
 14. 
.     * --- Completeness: fraction of true entities in only 1 predicted cluster
>  ---
.     bysort `entity_var' `cluster_var': gen byte `tag2' = (_n == 1)
 15.     bysort `entity_var': egen int `n_clusters' = total(`tag2')
 16. 
.     tempvar is_complete
 17.     bysort `entity_var': gen byte `is_complete' = (`n_clusters' == 1)
 18.     tempvar entity_tag
 19.     bysort `entity_var': gen byte `entity_tag' = (_n == 1)
 20.     quietly count if `entity_tag' == 1
 21.     local total_entities = r(N)
 22.     quietly count if `entity_tag' == 1 & `is_complete' == 1
 23.     local complete_entities = r(N)
 24.     local completeness = `complete_entities' / `total_entities'
 25. 
.     * --- F1 ---
.     local f1 = 2 * `purity' * `completeness' / (`purity' + `completeness')
 26. 
.     display as text ""
 27.     display as text "  Linkage Quality Metrics:"
 28.     display as text "  {hline 40}"
 29.     display as text "  Purity (precision):     " as result %6.3f `purity' 
>  ///
>         as text "  (`pure_clusters'/`total_clusters' clusters)"
 30.     display as text "  Completeness (recall):  " as result %6.3f `complete
> ness' ///
>         as text "  (`complete_entities'/`total_entities' entities)"
 31.     display as text "  F1 score:               " as result %6.3f `f1'
 32.     display as text "  {hline 40}"
 33. 
.     return scalar purity = `purity'
 34.     return scalar completeness = `completeness'
 35.     return scalar f1 = `f1'
 36.     return scalar total_clusters = `total_clusters'
 37.     return scalar total_entities = `total_entities'
 38. end

. 
. 
